# Database
# *.db 는 일반적으로 제외하되, GitHub Actions가 축적하는 추천 DB는 예외로 추적.
# 로컬에서 DB 변경이 git status에 나타나지 않게 하려면:
#   git update-index --skip-worktree data/storage/stock_analysis.db
*.db
!data/storage/stock_analysis.db

# OS
.DS_Store

# Test / Coverage
.pytest_cache/
.coverage
htmlcov/

# Models
# .pkl 및 model_params/*.json 은 GitHub Actions 배포를 위해 git에 포함
# (전체 크기 ~1MB로 LFS 불필요)
data/storage/pykrx_cache_*.pkl

# Runtime caches
data/storage/dart_corp_cache.json

# CatBoost training logs (auto-generated, not needed in repo)
catboost_info/

.aider*
